# Dockerfile for aria-call-handler Railway service
# In Railway: Service Settings → Build → Dockerfile Path → Dockerfile.call_handler

FROM python:3.12-slim

WORKDIR /app

# Install dependencies first (cached layer)
COPY requirements.call_handler.txt .
RUN pip install --no-cache-dir -r requirements.call_handler.txt

# Copy only the files this service needs
COPY call_handler.py .
COPY railway_security.py .

EXPOSE 8080

CMD ["uvicorn", "call_handler:app", "--host", "0.0.0.0", "--port", "8080"]
