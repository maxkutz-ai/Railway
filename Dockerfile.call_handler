FROM python:3.12-slim

WORKDIR /app

# Inline requirements — no external file dependency
RUN pip install --no-cache-dir \
    fastapi==0.135.2 \
    uvicorn==0.42.0 \
    websockets==15.0.1 \
    httpx==0.27.0 \
    supabase==2.10.0 \
    python-multipart==0.0.12 \
    python-dotenv==1.0.0 \
    twilio==9.3.0 \
    cryptography==42.0.8

COPY call_handler.py .
COPY encryption.py .
COPY railway_security.py .

EXPOSE 8080

CMD ["uvicorn", "call_handler:app", "--host", "0.0.0.0", "--port", "8080"]
