# Dockerfile for aria-agent Railway service
# In Railway: Service Settings → Build → Dockerfile Path → Dockerfile.aria_agent

FROM python:3.12-slim

WORKDIR /app

# Install dependencies first (cached layer)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy only the files this service needs
COPY aria_agent.py .
COPY aria_webhook.py .
COPY railway_security.py .

CMD ["python", "aria_agent.py", "start"]
